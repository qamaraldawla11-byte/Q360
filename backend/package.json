{
    "name": "one-os-backend",
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "start": "node dist/index.js",
        "build": "tsc",
        "db:push": "drizzle-kit push",
        "db:seed": "tsx src/db/seed.ts",
        "db:migrate:restaurant": "tsx src/db/migrate_restaurant_core.ts",
        "db:backup": "tsx src/scripts/backup.ts",
        "db:backup:list": "tsx src/scripts/backup.ts --list",
        "verify:restaurant": "tsx src/scripts/verify_restaurant_core.ts",
        "verify:restaurant-service-flow": "tsx src/scripts/verify_restaurant_service_flow.ts",
        "verify:restaurant-setup": "tsx src/scripts/verify_restaurant_setup_foundation.ts",
        "verify:business-pulse": "tsx src/scripts/verify_business_pulse_snapshot.ts",
        "verify:tenant-identity": "tsx src/scripts/verify_tenant_identity.ts",
        "verify:jwt-init": "tsx src/scripts/verify_jwt_init.ts",
        "verify:otp": "tsx src/scripts/verify_otp.ts",
        "verify:resend-live": "node dist/scripts/verify_resend_live.js"
    },
    "dependencies": {
        "@hono/node-server": "^2.0.4",
        "@supabase/supabase-js": "^2.108.2",
        "dotenv": "^17.2.3",
        "drizzle-orm": "^0.45.2",
        "hono": "^4.12.25",
        "postgres": "^3.4.9",
        "resend": "^6.14.0",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/uuid": "^10.0.0",
        "drizzle-kit": "^0.31.8",
        "tsx": "^4.7.0",
        "typescript": "^5.0.0"
    }
}
