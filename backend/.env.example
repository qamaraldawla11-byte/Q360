# One OS Backend Environment Variables

# REQUIRED: JWT Secret for token signing (generate a strong random string)
# IMPORTANT: Change this to a unique, secure value in production!
JWT_SECRET=your-secure-jwt-secret-here

# Server Port (default: 3001)
PORT=3001

# Production CORS Origins (comma-separated, add your production domain)
# CORS_ORIGINS=https://your-production-domain.com
