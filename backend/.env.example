# Q360 backend environment example

NODE_ENV=development

# Railway supplies PORT automatically.
PORT=3001

# Required JWT signing secret. Use a long random value in production.
JWT_SECRET=replace-with-a-long-random-development-secret

# Comma-separated frontend origins allowed to call the API.
CORS_ORIGINS=http://localhost:5174

# Postgres connection string. Use a local, staging, or Supabase pooled Postgres URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
POSTGRES_SSL=true
POSTGRES_POOL_SIZE=10

# Optional Supabase API client. Required only for direct Supabase service-role calls.
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Resend HTTPS API delivery for one-time sign-in codes.
RESEND_API_KEY=
EMAIL_FROM=Q360 <no-reply@send.q360.app>

# Q external AI is server-only. Never place these values in Vercel, frontend
# source code, GitHub, screenshots, or chat. Keep it disabled until a paid
# provider and an explicit release are approved.
# Supported providers: openai (default), kimi
Q_AI_PROVIDER=openai
Q_AI_MODEL=
Q_AI_API_KEY=
# Optional per-provider base URL. Defaults: OpenAI https://api.openai.com/v1,
# Kimi https://api.moonshot.ai/v1
Q_AI_BASE_URL=
# Default and strong models for Kimi. OpenAI still uses Q_OPENAI_MODEL or Q_AI_MODEL.
Q_AI_DEFAULT_MODEL=moonshot-v1-8k
Q_AI_STRONG_MODEL=kimi-k2.6
Q_AI_EXTERNAL_ENABLED=false
Q_MONTHLY_BUDGET_USD=10

# Backups are handled by Supabase Postgres backups/PITR or pg_dump.
