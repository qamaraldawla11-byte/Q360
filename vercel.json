{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "experimentalServices": {
    "frontend": {
      "root": ".",
      "workspace": ".",
      "entrypoint": ".",
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm run build"
    },
    "backend": {
      "root": "backend",
      "workspace": "backend",
      "entrypoint": "src/index.ts",
      "routePrefix": "/api",
      "framework": "nodejs",
      "builder": "nodejs22.x",
      "installCommand": "npm install"
    }
  }
}
