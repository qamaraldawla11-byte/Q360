# One OS environment example
#
# Copy the relevant values into local .env files.
# Frontend variables are read by Vite from the repository root.
# Backend variables are read by dotenv when the backend process starts.

# Frontend API base URL. Set this to the Railway API URL in Vercel.
VITE_API_BASE_URL=http://localhost:3001/api

# Frontend simulation flag. Current code primarily uses real API services where wired.
VITE_SIMULATION_MODE=false

# Backend runtime environment.
NODE_ENV=development

# Backend HTTP port.
PORT=3001

# Required backend JWT signing secret. Replace with a long random value.
JWT_SECRET=replace-with-a-long-random-development-secret

# Comma-separated frontend origins allowed to call the API.
# Railway example: https://one-os.vercel.app
CORS_ORIGINS=http://localhost:5174

# Postgres connection string. Use a local, staging, or Supabase pooled Postgres URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
POSTGRES_SSL=true
POSTGRES_POOL_SIZE=10

# Optional Supabase API client. Required only for direct Supabase service-role calls.
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Email delivery for one-time sign-in codes.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=One OS <no-reply@example.com>

# Local development only: logs the generated email JSON instead of using SMTP.
SMTP_JSON_TRANSPORT=false

# Backups are handled by Supabase Postgres backups/PITR or pg_dump.
