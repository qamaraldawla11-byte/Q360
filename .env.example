# One OS environment example
#
# Copy the relevant values into local .env files.
# Frontend variables are read by Vite from the repository root.
# Backend variables are read by dotenv when the backend process starts.

# Frontend API base URL.
VITE_API_BASE_URL=http://localhost:3001/api

# Frontend simulation flag. Current code primarily uses real API services where wired.
VITE_SIMULATION_MODE=false

# Backend runtime environment.
NODE_ENV=development

# Backend HTTP port.
PORT=3001

# Required backend JWT signing secret. Replace with a long random value.
JWT_SECRET=replace-with-a-long-random-development-secret

# Comma-separated allowed production origins in addition to localhost defaults.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional backup script settings.
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
